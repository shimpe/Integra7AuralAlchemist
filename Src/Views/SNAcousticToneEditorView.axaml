<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Integra7AuralAlchemist.ViewModels"
             xmlns:controls="using:Integra7AuralAlchemist.Controls"
             x:DataType="vm:SNAcousticToneEditorViewModel"
             x:CompileBindings="True"
             x:Name="Root"
             x:Class="Integra7AuralAlchemist.Views.SNAcousticToneEditorView">

    <UserControl.Styles>
        <!-- Reserve a uniform 2-line height for control labels so wrapped labels don't push their
             slider/combo down — keeps every control in a row vertically aligned. -->
        <Style Selector="TextBlock.sliderLabel">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="8">

        <!-- ===== Tone Header ===== -->
        <Border Grid.Row="0" Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <!-- Horizontal scrolling stays OFF: a ScrollViewer that scrolls horizontally measures its
                 content with unbounded width, so the WrapPanels below would never see a limit to wrap
                 at and would lay out on one endless line. It still clips, which is what we want. -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
            <StackPanel Spacing="8">
              <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                <StackPanel Spacing="2">
                    <Border Background="{StaticResource SnAccentBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                        <TextBlock Text="SuperNATURAL Acoustic" Foreground="{StaticResource SnBadgeForegroundBrush}" FontSize="11"/>
                    </Border>
                    <TextBlock Text="{Binding ToneName.Value}" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Spacing="2" Width="160">
                    <TextBlock Text="Tone Level"/>
                    <controls:ValueSlider Minimum="0" Maximum="127" Value="{Binding ToneLevel.Value, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock Text="Voice" ToolTip.Tip="Mono-Poly"/>
                    <ComboBox ItemsSource="{Binding MonoPoly.Options}"
                              SelectedItem="{Binding MonoPoly.Value, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Spacing="2" Width="150">
                    <TextBlock Text="Octave Shift" ToolTip.Tip="Octave Shift"/>
                    <controls:ValueSlider Minimum="-3" Maximum="3" Value="{Binding OctaveShift.Value, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Spacing="2" Width="150">
                    <TextBlock Text="Portamento" ToolTip.Tip="Portamento Time Offset"/>
                    <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding PortamentoOffset.Value, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock Text="Category" ToolTip.Tip="Category"/>
                    <NumericUpDown Width="110" Minimum="0" Maximum="127" Increment="1" FormatString="0"
                                   Value="{Binding Category.Value, Mode=TwoWay}"/>
                </StackPanel>
              </WrapPanel>

              <!-- Phrase (arpeggio) on its own row, mirroring the SN-S header -->
              <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                <StackPanel Spacing="2" Width="260">
                    <TextBlock Text="Phrase (arpeggio)" ToolTip.Tip="Phrase Number"/>
                    <ComboBox MaxDropDownHeight="300" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding PhraseNumber.Options}"
                              SelectedItem="{Binding PhraseNumber.Value, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Phrase Octave" ToolTip.Tip="Phrase Octave Shift"/>
                    <NumericUpDown Width="110" Minimum="-3" Maximum="3" Increment="1" FormatString="0"
                                   Value="{Binding PhraseOctaveShift.Value, Mode=TwoWay}"/>
                </StackPanel>
              </WrapPanel>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== Tone / FX ===== -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
            <ContentControl Grid.Column="0" Content="{Binding NoteRail}" Margin="0,0,8,0"/>
            <TabControl Grid.Column="1">
            <TabItem Header="Tone">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12" Margin="0,0,0,8">

                        <!-- Instrument detail section (family picker + per-instrument modify params) -->
                        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Instrument" FontWeight="Bold"/>
                                <ContentControl Content="{Binding Instrument}"/>
                            </StackPanel>
                        </Border>

                        <!-- Character -->
                        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Character" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Brightness (Cutoff)" Classes="sliderLabel" ToolTip.Tip="Cutoff Offset"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding CutoffOffset.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Resonance" Classes="sliderLabel" ToolTip.Tip="Resonance Offset"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding ResonanceOffset.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Attack" Classes="sliderLabel" ToolTip.Tip="Attack Time Offset"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding AttackOffset.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Release" Classes="sliderLabel" ToolTip.Tip="Release Time Offset"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding ReleaseOffset.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Vibrato Rate" Classes="sliderLabel" ToolTip.Tip="Vibrato Rate"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding VibratoRate.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Vibrato Depth" Classes="sliderLabel" ToolTip.Tip="Vibrato Depth"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding VibratoDepth.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="2" Width="150">
                                        <TextBlock Text="Vibrato Delay" Classes="sliderLabel" ToolTip.Tip="Vibrato Delay"/>
                                        <controls:ValueSlider Minimum="-64" Maximum="63" Value="{Binding VibratoDelay.Value, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Tone FX -->
                        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Tone FX" FontWeight="Bold"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Tone FX switch" Classes="sliderLabel" ToolTip.Tip="TFX Switch"/>
                                    <ToggleSwitch OnContent="On" OffContent="Off"
                                                  IsChecked="{Binding TfxSwitch.Value, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button HorizontalAlignment="Left" Content="Advanced acoustic parameters…"
                                Command="{Binding AdvancedAcousticCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="FX">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ContentControl Content="{Binding Mfx}" Margin="0,8,0,0"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        </Grid>
    </Grid>
</UserControl>

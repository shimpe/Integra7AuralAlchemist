<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Integra7AuralAlchemist.ViewModels"
             xmlns:controls="using:Integra7AuralAlchemist.Controls"
             x:DataType="vm:SNAcousticToneEditorViewModel"
             x:CompileBindings="True"
             x:Name="Root"
             x:Class="Integra7AuralAlchemist.Views.SNAcousticToneEditorView">

    <UserControl.Styles>
        <!-- Reserve a uniform 2-line height for control labels so wrapped labels don't push their
             slider/combo down — keeps every control in a row vertically aligned. -->
        <Style Selector="TextBlock.sliderLabel">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="8">

        <!-- ===== Tone Header ===== -->
        <Border Grid.Row="0" Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <!-- Horizontal scrolling stays OFF: a ScrollViewer that scrolls horizontally measures its
                 content with unbounded width, so the WrapPanels below would never see a limit to wrap
                 at and would lay out on one endless line.

                 Vertical scrolling is ON with a ceiling. Wrapping makes the header grow on a narrow
                 window, and this row is Auto-sized, so without a cap it grows until it fills the
                 window and pushes the rack, partial card and tabs off the bottom. Capped, it wraps
                 freely up to the ceiling and scrolls beyond it, and the editor below keeps its
                 space. At a normal width the content is shorter than the cap, so no bar appears. -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                          MaxHeight="300">

            <StackPanel Spacing="8">
              <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="8">
                <StackPanel Spacing="1">
                    <Border Background="{StaticResource SnAccentBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                        <TextBlock Text="SuperNATURAL Acoustic" Foreground="{StaticResource SnBadgeForegroundBrush}" FontSize="11"/>
                    </Border>
                    <TextBlock Text="{Binding ToneName.Value}" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Spacing="1" Width="76">
                    <TextBlock Text="Tone Level"/>
                    <controls:RotaryKnob Minimum="0" Maximum="127" Value="{Binding ToneLevel.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobAmpBrush}"/>
                </StackPanel>

                <StackPanel Spacing="1">
                    <TextBlock Text="Voice" ToolTip.Tip="Mono-Poly"/>
                    <ComboBox ItemsSource="{Binding MonoPoly.Options}"
                              SelectedItem="{Binding MonoPoly.Value, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Spacing="1" Width="76">
                    <TextBlock Text="Octave Shift" ToolTip.Tip="Octave Shift"/>
                    <controls:RotaryKnob Minimum="-3" Maximum="3" Value="{Binding OctaveShift.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobPitchDriftBrush}"/>
                </StackPanel>

                <StackPanel Spacing="1" Width="76">
                    <TextBlock Text="Portamento" ToolTip.Tip="Portamento Time Offset"/>
                    <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding PortamentoOffset.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobPitchDriftBrush}"/>
                </StackPanel>

                <StackPanel Spacing="1">
                    <TextBlock Text="Category" ToolTip.Tip="Category"/>
                    <controls:RotaryKnob Minimum="0" Maximum="127"
                                   Value="{Binding Category.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobCommonBrush}"/>
                </StackPanel>
              </WrapPanel>

              <!-- Phrase (arpeggio) on its own row, mirroring the SN-S header -->
              <WrapPanel Orientation="Horizontal" ItemSpacing="6" LineSpacing="8">
                <StackPanel Spacing="1" Width="260">
                    <TextBlock Text="Phrase (arpeggio)" ToolTip.Tip="Phrase Number"/>
                    <ComboBox MaxDropDownHeight="300" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding PhraseNumber.Options}"
                              SelectedItem="{Binding PhraseNumber.Value, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Spacing="1">
                    <TextBlock Text="Phrase Octave" ToolTip.Tip="Phrase Octave Shift"/>
                    <controls:RotaryKnob Minimum="-3" Maximum="3"
                                   Value="{Binding PhraseOctaveShift.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobPitchDriftBrush}"/>
                </StackPanel>
              </WrapPanel>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== Tone / FX ===== -->
        <!-- Scrolls sideways when the window is too narrow for the rack, the partial list and a
             usable parameter editor. MinWidth keeps the grid filling the window while it fits, so the
             star column still stretches and no bar appears; below that the grid keeps its natural
             width and scrolls, instead of squeezing the editor down to nothing. -->
        <ScrollViewer Grid.Row="1" x:Name="RackScroll" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
        <Grid MinWidth="{Binding #RackScroll.Viewport.Width}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Never squeezed below a usable width; the grid scrolls sideways instead. -->
            <ColumnDefinition Width="*" MinWidth="420"/>
          </Grid.ColumnDefinitions>

            <ContentControl Grid.Column="0" Content="{Binding NoteRail}" Margin="0,0,8,0"/>
            <TabControl Grid.Column="1">
            <TabItem Header="Tone">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="6" Margin="0,0,0,8">

                        <!-- Instrument detail section (family picker + per-instrument modify params) -->
                        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Instrument" FontWeight="Bold"/>
                                <ContentControl Content="{Binding Instrument}"/>
                            </StackPanel>
                        </Border>

                        <!-- Character -->
                        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Character" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Brightness (Cutoff)" Classes="sliderLabel" ToolTip.Tip="Cutoff Offset"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding CutoffOffset.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobFilterBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Resonance" Classes="sliderLabel" ToolTip.Tip="Resonance Offset"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding ResonanceOffset.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobFilterBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Attack" Classes="sliderLabel" ToolTip.Tip="Attack Time Offset"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding AttackOffset.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobAmpBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Release" Classes="sliderLabel" ToolTip.Tip="Release Time Offset"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding ReleaseOffset.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobAmpBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Vibrato Rate" Classes="sliderLabel" ToolTip.Tip="Vibrato Rate"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding VibratoRate.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobLfoBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Vibrato Depth" Classes="sliderLabel" ToolTip.Tip="Vibrato Depth"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding VibratoDepth.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobLfoBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="1" Width="76">
                                        <TextBlock Text="Vibrato Delay" Classes="sliderLabel" ToolTip.Tip="Vibrato Delay"/>
                                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding VibratoDelay.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobLfoBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Tone FX -->
                        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Tone FX" FontWeight="Bold"/>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="Tone FX switch" Classes="sliderLabel" ToolTip.Tip="TFX Switch"/>
                                    <ToggleSwitch OnContent="On" OffContent="Off"
                                                  IsChecked="{Binding TfxSwitch.Value, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Button HorizontalAlignment="Left" Content="Advanced acoustic parameters…"
                                Command="{Binding AdvancedAcousticCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="FX">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ContentControl Content="{Binding Mfx}" Margin="0,8,0,0"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

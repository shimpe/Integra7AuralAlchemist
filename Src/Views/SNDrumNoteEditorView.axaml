<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Integra7AuralAlchemist.ViewModels"
             xmlns:controls="using:Integra7AuralAlchemist.Controls"
             x:DataType="vm:SNDrumNoteEditorViewModel"
             x:CompileBindings="True"
             x:Class="Integra7AuralAlchemist.Views.SNDrumNoteEditorView">
    <UserControl.Styles>
        <Style Selector="TextBlock.sliderLabel">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
    </UserControl.Styles>
    <StackPanel Spacing="6" Margin="0,0,0,8">

        <!-- Sound -->
        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Drum sound" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="1">
                    <AutoCompleteBox x:Name="InstBox" Width="300" MaxDropDownHeight="320"
                                     MinimumPrefixLength="0" FilterMode="Contains"
                                     ItemsSource="{Binding InstNumber.Options}"
                                     SelectedItem="{Binding InstNumber.Value, Mode=TwoWay}"/>
                    <Button Content="â–¾" Padding="8,4" VerticalAlignment="Center"
                            Click="BrowseInst" ToolTip.Tip="Browse all drum sounds"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <StackPanel Spacing="1">
                        <TextBlock Text="Variation" ToolTip.Tip="Variation"/>
                        <ComboBox ItemsSource="{Binding Variation.Options}"
                                  SelectedItem="{Binding Variation.Value, Mode=TwoWay}"/>
                    </StackPanel>
                    <StackPanel Spacing="1">
                        <TextBlock Text="Output" ToolTip.Tip="Output Assign"/>
                        <ComboBox ItemsSource="{Binding OutputAssign.Options}"
                                  SelectedItem="{Binding OutputAssign.Value, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tweaks -->
        <Border Background="{StaticResource SnPanelBackgroundBrush}" CornerRadius="6" Padding="10">
            <StackPanel Spacing="8">
                <TextBlock Text="Tweaks" FontWeight="Bold"/>
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Level" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="0" Maximum="127" Value="{Binding Level.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobAmpBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Pan (L / C / R)" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="-64" Maximum="63" Value="{Binding Pan.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobPanBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="200" Margin="0,0,16,8">
                        <TextBlock Text="Tune (cents)" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="-1200" Maximum="1200" Value="{Binding Tune.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobPitchDriftBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Attack (%)" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="0" Maximum="100" Value="{Binding Attack.Value, Mode=TwoWay}" Unit="%" AccentBrush="{StaticResource KnobAmpBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Decay" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="-63" Maximum="0" Value="{Binding Decay.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobAmpBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Brilliance" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="-15" Maximum="12" Value="{Binding Brilliance.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobFilterBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Dynamic Range" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="0" Maximum="63" Value="{Binding DynamicRange.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobAmpBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Stereo Width" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="0" Maximum="127" Value="{Binding StereoWidth.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobCommonBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Chorus Send" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="0" Maximum="127" Value="{Binding ChorusSend.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobFxBrush}"/>
                    </StackPanel>
                    <StackPanel Spacing="1" Width="160" Margin="0,0,16,8">
                        <TextBlock Text="Reverb Send" Classes="sliderLabel"/>
                        <controls:RotaryKnob Minimum="0" Maximum="127" Value="{Binding ReverbSend.Value, Mode=TwoWay}" AccentBrush="{StaticResource KnobFxBrush}"/>
                    </StackPanel>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Copy drum" Command="{Binding CopyDrumCommand}"/>
                    <Button Content="Paste drum" Command="{Binding PasteDrumCommand}"/>
                    <Button Content="Init drum" Command="{Binding InitDrumCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Integra7AuralAlchemist.App"
             xmlns:local="using:Integra7AuralAlchemist"
             xmlns:sty="using:FluentAvalonia.Styling" RequestedThemeVariant="Dark">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <!-- SuperNATURAL Synth editor palette. Reference via {StaticResource ...}; never hardcode colors in XAML. -->
            <SolidColorBrush x:Key="SnPanelBackgroundBrush" Color="#22000000" />
            <SolidColorBrush x:Key="SnAccentBrush" Color="#3D7EAA" />
            <SolidColorBrush x:Key="SnBadgeForegroundBrush" Color="White" />
            <SolidColorBrush x:Key="SnCardBackgroundBrush" Color="#1E2226" />
            <SolidColorBrush x:Key="SnCardHoverBackgroundBrush" Color="#262B30" />
            <SolidColorBrush x:Key="SnCardSelectedBackgroundBrush" Color="#284A63" />
            <SolidColorBrush x:Key="SnCardSelectedBorderBrush" Color="#8FC4EF" />
            <!-- Envelope graph palette (Amp = blue, Filter = amber). -->
            <SolidColorBrush x:Key="SnEnvelopeBackgroundBrush" Color="#1B1F22" />
            <SolidColorBrush x:Key="SnEnvelopeGridBrush" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="SnEnvelopeAxisBrush" Color="#55FFFFFF" />
            <SolidColorBrush x:Key="SnEnvelopeHandleBrush" Color="White" />
            <SolidColorBrush x:Key="SnEnvelopeFocusBrush" Color="Orange" />
            <SolidColorBrush x:Key="SnAmpEnvelopeBrush" Color="#7FB6E0" />
            <SolidColorBrush x:Key="SnAmpEnvelopeFillBrush" Color="#553D7EAA" />
            <SolidColorBrush x:Key="SnFilterEnvelopeBrush" Color="#E0A23D" />
            <SolidColorBrush x:Key="SnFilterEnvelopeFillBrush" Color="#55B07A1E" />
            <SolidColorBrush x:Key="SnPitchEnvelopeBrush" Color="#9C7BE0" />
            <SolidColorBrush x:Key="SnPitchEnvelopeFillBrush" Color="#556A4FB0" />
            <SolidColorBrush x:Key="SnLfoWaveformBrush" Color="#4FB0A0" />
            <SolidColorBrush x:Key="SnSoloBrush" Color="#4FB06A"/>
            <SolidColorBrush x:Key="SnMuteBrush" Color="#C25A4F"/>
            <SolidColorBrush x:Key="SnAuditionBannerBrush" Color="#5A4A1E"/>
            <!-- De-emphasised text: secondary status that should not compete with the real content. -->
            <SolidColorBrush x:Key="SnMutedTextBrush" Color="#9AA2A8"/>
            <!-- Hairline separating the status bar from the content above it. -->
            <SolidColorBrush x:Key="SnStatusBarBorderBrush" Color="#33FFFFFF"/>
            <!-- Rotary-knob grouping palette. The accent strip colors a knob by the function it
                 belongs to, so related controls read as a set. Pitch/Filter/Amp reuse the envelope
                 hues so a section's knobs match its envelope graph; the rest are distinct accents. -->
            <SolidColorBrush x:Key="KnobPitchBrush" Color="#9C7BE0" />
            <SolidColorBrush x:Key="KnobFilterBrush" Color="#E0A23D" />
            <SolidColorBrush x:Key="KnobAmpBrush" Color="#7FB6E0" />
            <SolidColorBrush x:Key="KnobPanBrush" Color="#4FB0A0" />
            <SolidColorBrush x:Key="KnobPitchDriftBrush" Color="#C08AD1" />
            <SolidColorBrush x:Key="KnobLfoBrush" Color="#5FB0C9" />
            <SolidColorBrush x:Key="KnobFxBrush" Color="#B0895F" />
            <SolidColorBrush x:Key="KnobCommonBrush" Color="#8FA0B0" />

            <!-- PCM Synth PMT zone palette. -->
            <SolidColorBrush x:Key="PmtZone1Brush" Color="#6b8dff"/>
            <SolidColorBrush x:Key="PmtZone2Brush" Color="#ff9e6b"/>
            <SolidColorBrush x:Key="PmtZone3Brush" Color="#7ad19a"/>
            <SolidColorBrush x:Key="PmtZone4Brush" Color="#d18ad1"/>
            <!-- Drum note-rail key palette (SN-Drums + PCM-Drums). -->
            <SolidColorBrush x:Key="DrumWhiteKeyBrush" Color="#c8ccce"/>
            <SolidColorBrush x:Key="DrumBlackKeyBrush" Color="#23262a"/>
            <SolidColorBrush x:Key="DrumKeyBorderBrush" Color="#888888"/>
            <SolidColorBrush x:Key="ToneKeyOutOfRangeWhiteBrush" Color="#9a9ea1"/>
            <SolidColorBrush x:Key="ToneKeyOutOfRangeBlackBrush" Color="#34383c"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <sty:FluentAvaloniaTheme PreferUserAccentColor="True" />

        <!-- Scrollbars reserve space instead of floating over the content. Avalonia's default is to
             overlay them, which puts a scrollbar on top of whatever sits at the edge of a scrolling
             area: a combo box in the SN-S header, the right hand side of a partial card. Measured on
             Avalonia 12.0.5 with AllowAutoHide left on, the viewport is the scroll viewer's full
             size, so the bar has nowhere to go but over the content. Turning it off reserves 16px on
             each scrolling axis instead. -->
        <Style Selector="ScrollViewer">
            <Setter Property="ScrollViewer.AllowAutoHide" Value="False" />
        </Style>
    </Application.Styles>
</Application>
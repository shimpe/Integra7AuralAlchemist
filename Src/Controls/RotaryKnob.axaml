<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Integra7AuralAlchemist.Controls"
             x:Name="Root"
             x:Class="Integra7AuralAlchemist.Controls.RotaryKnob">
    <UserControl.Styles>
        <!-- The dial is owner-drawn, so it does not fade on its own when the knob is disabled the way
             the themed text box does. Dim it to match. IsEnabled propagates to the child dial, so its
             :disabled pseudo-class tracks the knob's. -->
        <Style Selector="controls|RotaryKnobDial:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>

        <!-- The base background comes from the TextBox.Background binding above. FluentAvalonia swaps
             the border's fill to its own theme brushes on hover and focus, which flickered the accent
             away, so pin the template border to the accent on those two states. -->
        <Style Selector="TextBox#Editor:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background"
                    Value="{Binding AccentBrush, RelativeSource={RelativeSource AncestorType=controls:RotaryKnob}}" />
        </Style>
        <Style Selector="TextBox#Editor:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background"
                    Value="{Binding AccentBrush, RelativeSource={RelativeSource AncestorType=controls:RotaryKnob}}" />
        </Style>

        <!-- Dark, fixed text on the accent background, on every state, so focus does not swap it to the
             theme's light foreground and drop the contrast. -->
        <Style Selector="TextBox#Editor">
            <Setter Property="Foreground" Value="{StaticResource KnobEditForegroundBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource KnobEditForegroundBrush}" />
        </Style>
        <Style Selector="TextBox#Editor:pointerover">
            <Setter Property="Foreground" Value="{StaticResource KnobEditForegroundBrush}" />
        </Style>
        <Style Selector="TextBox#Editor:focus">
            <Setter Property="Foreground" Value="{StaticResource KnobEditForegroundBrush}" />
        </Style>
    </UserControl.Styles>
    <StackPanel Spacing="0" HorizontalAlignment="Center">
        <controls:RotaryKnobDial x:Name="Dial" Width="40" Height="40"
                                 HorizontalAlignment="Center"
                                 Minimum="{Binding #Root.Minimum}"
                                 Maximum="{Binding #Root.Maximum}"
                                 Value="{Binding #Root.Value, Mode=TwoWay}"
                                 AccentBrush="{Binding #Root.AccentBrush}"/>
        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
            <TextBox x:Name="Editor" MinWidth="34" MaxWidth="56"
                     MinHeight="0" Height="20" Padding="3,0" FontSize="11" TextAlignment="Right"
                     VerticalContentAlignment="Center"
                     Background="{Binding #Root.AccentBrush}"
                     Text="{Binding #Root.EditText, Mode=TwoWay}"/>
            <TextBlock x:Name="UnitText" VerticalAlignment="Center" Opacity="0.7" FontSize="10"
                       Text="{Binding #Root.Unit}"
                       IsVisible="{Binding #Root.HasUnit}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
